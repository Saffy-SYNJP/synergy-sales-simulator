# ============================================================
# Synergy Sales Training Engine — Environment Variables
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.
# Restart `npm run dev` after making any changes.
# ============================================================

# ----------------------------------------------------------
# REQUIRED — Anthropic Claude API
# Get your key at: https://console.anthropic.com/settings/keys
# ----------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-key-here

# ----------------------------------------------------------
# OPTIONAL — Override the default Claude model
# Default is claude-sonnet-4-6. Do not change unless instructed.
# ----------------------------------------------------------
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ----------------------------------------------------------
# VOICE PHASE 2 — Set to "true" to enable voice features
# Leave as "false" until Deepgram + ElevenLabs keys are ready.
# When false, the app runs in text-only mode (current default).
# ----------------------------------------------------------
NEXT_PUBLIC_VOICE_ENABLED=false

# ----------------------------------------------------------
# DEEPGRAM — Speech-to-Text (STT)
# Required when NEXT_PUBLIC_VOICE_ENABLED=true
# Get your key at: https://console.deepgram.com
# Model used: Nova-2
# ----------------------------------------------------------
DEEPGRAM_API_KEY=

# ----------------------------------------------------------
# ELEVENLABS — Text-to-Speech (TTS)
# Required when NEXT_PUBLIC_VOICE_ENABLED=true
# Get your key at: https://elevenlabs.io
# Model used: eleven_flash_v2_5 (lowest latency)
# ----------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Voice IDs — find these in ElevenLabs Voice Library
# Assign a distinct voice per market persona + AI Rep + Coach
ELEVENLABS_VOICE_PHILIPPINES=
ELEVENLABS_VOICE_VIETNAM=
ELEVENLABS_VOICE_MYANMAR=
ELEVENLABS_VOICE_CAMBODIA=
ELEVENLABS_VOICE_AI_REP=
ELEVENLABS_VOICE_COACH=
