{
  "framework": "nextjs",
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/summary/route.ts": {
      "maxDuration": 60
    },
    "app/api/tts/route.ts": {
      "maxDuration": 30
    },
    "app/api/stt/route.ts": {
      "maxDuration": 30
    },
    "app/api/stt/token/route.ts": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
